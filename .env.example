# Cutoff time (24h format, default: 10:00)
CUTOFF_TIME=10:00

# Timezone (default: America/New_York)
TIMEZONE=America/New_York

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Discord bot token for message monitoring
DISCORD_BOT_TOKEN=

# Discord channel ID to monitor
DISCORD_CHANNEL_ID=

# Sign-in keywords (comma-separated, default: here,present,checking in,check-in)
SIGNIN_KEYWORDS=here,present,checking in,check-in

# Active hours window for auto-signin (24h format)
ACTIVE_HOURS_START=08:00
ACTIVE_HOURS_END=10:00

# Google Sheets service account JSON (entire JSON string, escaped)
GOOGLE_SHEETS_CREDENTIALS=

# Google Sheet ID (from sheet URL)
GOOGLE_SHEET_ID=

# Comma-separated holiday dates (YYYY-MM-DD format)
HOLIDAYS=

# Poll interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# Health check HTTP port (default: 8080)
PORT=8080
